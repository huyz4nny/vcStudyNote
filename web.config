<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Điều hướng tất cả request vào thư mục studynote-web (nơi chứa Frontend) -->
                <rule name="Serve Frontend from studynote-web folder" stopProcessing="true">
                    <match url="^(.*)$" />
                    <conditions logicalGrouping="MatchAll">
                        <!-- Tránh vòng lặp vô hạn nếu request đã nằm trong thư mục này -->
                        <add input="{REQUEST_URI}" pattern="^/studynote-web/" negate="true" />
                        <!-- Bỏ qua thư mục API để tránh bị ghi đè (nếu sau này API nằm chung server) -->
                        <add input="{REQUEST_URI}" pattern="^/StudyNote\.API/" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="/studynote-web/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
